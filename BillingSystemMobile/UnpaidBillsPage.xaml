<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BillingSystemMobile.UnpaidBillsPage"
             Title="Unpaid Bills"
             BackgroundColor="#F5F5F5">


    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">


            <Label x:Name="lblWelcome"
                   Text="Welcome"
                   FontSize="20"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#1F4E79"
                   Margin="0,0,0,4"/>

            <Label Text="Your Unpaid Bills"
                   FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="#777777"
                   Margin="0,0,0,10"/>

            <VerticalStackLayout x:Name="stackBills" Spacing="10"/>

            <VerticalStackLayout x:Name="stackEmpty" IsVisible="False"/>

            <Button x:Name="btnLogout"
                Text="Log Out"
                BackgroundColor="Transparent"
                TextColor="#C0392B"
                BorderColor="#C0392B"
                BorderWidth="1"
                FontSize="14"
                Margin="0,8,0,0"
                Clicked="OnLogoutClicked"/>

        </VerticalStackLayout>
    </ScrollView>


</ContentPage>